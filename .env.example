# Copy to .env (or use .env.local) and adjust.

# Local Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/easter"

# Neon (set only in production / hosting env — never commit the real URL)
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Gmail SMTP (use an App Password from Google account security settings)
GMAIL_USER="your@gmail.com"
GMAIL_APP_PASSWORD="your_16_char_app_password"

# Public app URL used in email links (include scheme, no trailing slash preferred)
APP_URL="http://localhost:3000"

# Admin access is per room: each room has its own admin key (see email after creating a room).
